{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "lib": [
            "ESNext"
        ],
        "moduleResolution": "node",
        "strict": true,
        "allowJs": true,
        "checkJs": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "types": [
            "@cloudflare/workers-types",
            "node"
        ]
    },
    "include": [
        "src/**/*"
    ]
}